# --- Identite de l'instance (override config.js sans push) ---
# Numero WhatsApp a appairer (avec indicatif pays, sans + ni espaces).
PHONE_NUMBER=
# Numero du proprietaire affiche dans la banniere de connexion.
OWNER_NUMBER=
# Nom affiche dans la banniere.
OWNER_NAME=
# "true" pour utiliser un Pairing Code (8 chiffres, plus simple sur Render),
# "false" pour un QR a scanner. Render Free : true recommande.
USE_PAIRING_CODE=true

# Lecture + reaction automatique aux statuts WhatsApp des contacts.
# Mettre "false" pour desactiver completement la reaction aux statuts.
STATUS_AUTO_REACT=true

# Envoie un DOUBLON de la reaction directement dans le chat prive du posteur
# du statut. Astuce historique pour declencher la notif "a reagi a votre
# statut" sur le mobile du posteur. Inconvenient : c'est un vrai message
# Signal-chiffre qui arrive dans le chat prive, donc si la session est
# desynchronisee (typique post-re-pairing), il s'affiche comme "En attente
# de ce message" chez le contact, generant du spam visible.
# Defaut : false (recommande). Mettre "true" pour reactiver l'astuce.
STATUS_REACT_PRIVATE_NOTIFY=false

# --- Cles API IA (au moins une recommandee) ---
# Gemini : https://aistudio.google.com/apikey  (gratuit, genereux)
GEMINI_API_KEY=

# Optionnels (fallback automatique si Gemini indisponible)
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# --- Hebergement Render / Railway / Fly (optionnel) ---
# Stockage distant de la session WhatsApp (filesystem ephemere).
# Creer un projet sur https://supabase.com (plan gratuit), puis dans
# Project Settings > API, copier la `Project URL` et la `anon public key`.
# Creer la table requise (SQL editor) :
#   CREATE TABLE whatsapp_auth (id text PRIMARY KEY, data jsonb);
SUPABASE_URL=
SUPABASE_KEY=

# Identifiant unique de cette instance (prefixe les cles Supabase). Permet
# d'heberger plusieurs bots (un par ami) dans le meme projet Supabase sans
# qu'ils se marchent dessus. Ex: "ami_jean", "ami_marie". Laisser vide en
# mode mono-bot.
BOT_ID=

# URL publique du service Render pour l'auto-ping anti-sleep.
# Ex : https://mon-bot.onrender.com
RENDER_URL=

# Port HTTP (Render le definit automatiquement, ne pas toucher en local)
PORT=3000
