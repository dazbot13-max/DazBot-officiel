# --- Cles API IA (au moins une recommandee) ---
# Gemini : https://aistudio.google.com/apikey  (gratuit, genereux)
GEMINI_API_KEY=

# Optionnels (fallback automatique si Gemini indisponible)
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# --- Hebergement Render / Railway / Fly (optionnel) ---
# Stockage distant de la session WhatsApp (filesystem ephemere).
# Creer un projet sur https://supabase.com (plan gratuit), puis dans
# Project Settings > API, copier la `Project URL` et la `anon public key`.
# Creer la table requise (SQL editor) :
#   CREATE TABLE whatsapp_auth (id text PRIMARY KEY, data jsonb);
SUPABASE_URL=
SUPABASE_KEY=

# Identifiant unique de cette instance (prefixe les cles Supabase). Permet
# d'heberger plusieurs bots (un par ami) dans le meme projet Supabase sans
# qu'ils se marchent dessus. Ex: "ami_jean", "ami_marie". Laisser vide en
# mode mono-bot.
BOT_ID=

# URL publique du service Render pour l'auto-ping anti-sleep.
# Ex : https://mon-bot.onrender.com
RENDER_URL=

# Port HTTP (Render le definit automatiquement, ne pas toucher en local)
PORT=3000
